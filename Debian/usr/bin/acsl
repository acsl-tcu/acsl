#!/usr/bin/env bash
ACSL_VERSION="3.3"

#############################################################
# Assets
#############################################################
# Usageを表示
function usage() {
  echo $1
  cat <<_EOT_
Usage:
  $(basename $0) [-a] [-B] [-b bargv] ...

Description:
  XXX

Options:
  -a オプションa
  -B オプションB
  -b オプションbの引数値を指定
  -h ヘルプ表示

_EOT_
  exit 1
}

# オプションフラグ用変数初期化
function initOptionFlags() {
  for char in {{a..z},{A..Z}}; do
    eval OPT_FLAG_${char}=0
  done
}

# オプション解析結果を表示
function printOptions() {
  echo "### 指定オプション一覧"
  for char in {{a..z},{A..Z}}; do
    opt=$(eval echo \${OPT_FLAG_${char}:-""})
    optarg=$(eval echo \${OPT_VALUE_${char}:-""})
    if [[ $opt = 1 ]]; then
      echo "opt=-${char} ${optarg:+optarg=${optarg}}"
    fi
  done
  echo
}

function print_acsl_version() {
  echo "acsl ${ACSL_VERSION}"
}

##################################################
function git_pull() {
  .acsl/docker/common/scripts/gpull $1
}
function colcon_build() {
  .acsl/commands/scripts/build_project $@
}
function docker_push() {
  .acsl/commands/scripts/dpush image_${PROJECT}
}

function check_acsl() {
  if [[ -v ORGPATH ]]; then
    echo ACTIVE ACSL project
    echo "ACSL_WORK_DIR : $ACSL_WORK_DIR"
    echo "PROJECT : $PROJECT"
    echo "ROS Domain ID : $ROS_DOMAIN_ID"
    return 0
  else
    return 1
  fi
}

function change_dir_for_init() {
  if [ "${1-}" = "init" ]; then
    echo "Initialize project in current folder"
  elif [[ -d $1 ]]; then
    echo "Move to $1"
    cd $1
  else
    echo "Create new directory $1 for initialization"
    mkdir $1
    cd $1
  fi
}

function check_empty() {
  if [ -z "$(find . -mindepth 1 -print -quit)" ]; then
    return 0
  else
    return 1
  fi
}
###################################################
# Information
###################################################
function man() {
  case ${1} in
  "init")
    echo "Usage : acsl project_dir project_name ros_domain_id"
    ;;
  "install")
    echo "Usage : acsl install package_name"
    echo "To install package into your project"
    ;;
  "remove")
    echo "Usage : acsl remove package_name"
    echo "To remove package from your project"
    ;;
  "update_tag_list")
    echo "Usage : acsl update_tag_list"
    echo "To update tag list from docker hub"
    ;;
  "update") ;;
  "freeze") ;;
  "clean")
    echo "[Usage] acsl clean"
    echo "To clean up all"
    ;;
  "make_package")
    echo "[Usage] acsl make_package package_name"
    echo "create new package"
    echo "After setup the package, push it to github."
    echo "Then install the package into your project by acsl install package."
    echo "Build the docker image and dpush it."
    ;;
  esac
}
function update_tag_list() {
  # function to update tag_list file in $ACSL_ROS2_DIR
  echo UPDATE TAG_LIST
  cd $ACSL_ROS2_DIR
  git checkout .
  res=$(docker run --rm quay.io/skopeo/stable:v1.9.2 list-tags --debug docker://kasekiguchi/acsl-common)
  res=$(echo ${res##*[})
  res=$(echo ${res%%]*})
  echo ${res//,/} >$ACSL_ROS2_DIR/tag_list

  ## PROJECT_LIST
  echo UPDATE PROJECT_LIST
  project_list=$(gh repo list acsl-tcu | grep project | fmt | awk '{print $1}' | sed -e "s|acsl-tcu/project_||g")
  echo $project_list >$ACSL_ROS2_DIR/project_list

  ## PACKAGE_LIST
  echo UPDATE PACKAGE_LIST
  gh repo clone acsl-tcu/acsl_package temp
  cd temp
  git branch -a | grep /origin | grep -v HEAD | sed 's|remotes/origin/||g' >$ACSL_ROS2_DIR/package_list
  cd ..
  rm -fr temp

  ## 登録
  git add .
  git commit -m "update tag_list, package_list and project_list"
  git push
}

function dpull_check_tag() {
  # $1 = TAG_NAME
  # docker pull image with TAG_NAME if TAG_NAME in tag_list
  tag=$1
  res=$(cat $ACSL_ROS2_DIR/tag_list | grep -w $tag)
  if [[ -n $res ]]; then
    gecho DOCKER PULL: image $tag
    $ACSL_ROS2_DIR/commands/scripts/dpull $tag
  else
    recho "Not found the image with $tag\n Request update tag list"
  fi
}

function dockerfile_dpull() {
  # $1 = dockerfile.TAG_NAME
  # docker pull image with TAG_NAME if it exists
  TAG=${1##*dockerfile.}
  dpull_check_tag $TAG
}
function remove_systemd() {
  echo "Stop project_launch : systemctl stop project_launch"
  sudo systemctl stop project_launch
  echo "Delete /etc/systemd/system/project_launch.service"
  sudo rm -f /etc/systemd/system/project_launch.service
  echo "reload : systemctl daemon-reload"
  sudo systemctl daemon-reload
}

function remove_package_systemd() {
  echo "Remove systemd"
  PACKAGE=$1
  SYSD_FILE=project_launch.sh
  LAUNCHS="### $PACKAGE ###"
  LAUNCHE="### $PACKAGE END ###"
  lines=($(grep -n "$LAUNCHS" "$SYSD_FILE" | cut -d: -f1))
  linee=($(grep -n "$LAUNCHE" "$SYSD_FILE" | cut -d: -f1))
  if [[ -n $lines ]]; then
    sed -i -e "${lines},${linee}d" $SYSD_FILE
  fi
}
function setup_udev() {
  if [[ -f rules/${PROJECT}.rules ]]; then
    gecho "Setup UDEV"
    $ACSL_ROS2_DIR/commands/setup_udev rules/${PROJECT}.rules
  fi
}

function remove_udev() {
  echo "Delete : /etc/udev/rules.d/90-custom.rules"
  sudo rm -f /etc/udev/rules.d/90-custom.rules
  echo "Reload : udevadm control --reload-rules"
  sudo udevadm control --reload-rules
  echo "Start : udevadm trigger"
  sudo udevadm trigger
}

function set_package_udev() {
  if [[ -f ${1} ]]; then
    mkdir -p rules
    echo "### $PACKAGE ###" >>rules/${PROJECT}.rules
    cat ${1} >>rules/${PROJECT}.rules
    echo "### $PACKAGE END ###" >>rules/${PROJECT}.rules
  fi
}

function remove_package_udev() {
  echo "Remove udev"
  PACKAGE=$1
  UDEV_FILE=rules/${PROJECT}.rules
  RULES="### $PACKAGE ###"
  RULEE="### $PACKAGE END ###"
  lines=($(grep -n "$RULES" "$UDEV_FILE" | cut -d: -f1))
  linee=($(grep -n "$RULEE" "$UDEV_FILE" | cut -d: -f1))
  if [[ -n $lines ]]; then
    sed -i -e "${lines},${linee}d" $UDEV_FILE
  fi
  echo "Stop udev service"
  remove_udev
}
##############################################
## Initilize
# acsl init/project_dir PROJECT ROS_DOMAIN_ID
# init: initialize project on current directory
# project_dir: initialize project in this directory
# PROJECT : project name
# ROS_DOMAIN_ID : ROS Domain ID
# Example : acsl robot rf 10
##############################################
function initialize_project() {
  PROJECT=${1}
  ROS_DOMAIN_ID=$2

  ## Clone project repository
  echo "Load project: project_${PROJECT}"
  git clone git@github.com:acsl-tcu/project_${PROJECT} . --recurse-submodules
  ACSL_WORK_DIR="$(pwd)"
  ACSL_ROS2_DIR="$(pwd)/.acsl"
  echo "create .acsl folder"
  git clone git@github.com:acsl-tcu/acsl_infra.git .acsl --recurse-submodules
  git clone git@github.com:acsl-tcu/project_common.git common --recurse-submodules
  chmod -R a+rx,a-w $ACSL_WORK_DIR/common/
  mkdir -p $ACSL_WORK_DIR/Data
  chmod -R a+x $ACSL_ROS2_DIR/commands
  chmod -R a+x $ACSL_ROS2_DIR/docker/common/scripts
  chmod -R a+x $ACSL_WORK_DIR/launcher
  chmod a+x $ACSL_WORK_DIR/project_launch.sh
  source $ACSL_ROS2_DIR/docker/common/scripts/super_echo
  $ACSL_ROS2_DIR/commands/setup_bashrc $ACSL_WORK_DIR $@
  source $ACSL_ROS2_DIR/bashrc

  if [ -e setup ]; then
    gecho "Run setup"
    chmod a+x setup
    ./setup full
  else
    echo "No setup found, skip"
    dpull jazzy$x86
    dtag jazzy$x86 image_${PROJECT}${x86}
  fi

  gecho "Do following command every login
  acsl $ACSL_ROS2_DIR"

  bash --rcfile .acsl/bashrc
}
#############################################################
# package install
#############################################################

function install_package() {
  local PACKAGE=${1}
  local SAVED_DIR=$(pwd)

  echo "### 引数一覧"
  for argv in $@; do
    echo ${argv}
  done
  echo

  ####################################
  ##  Install package main
  ####################################
  if [[ ! -d $ACSL_WORK_DIR/.install ]]; then
    mkdir -p $ACSL_WORK_DIR/.install
    git clone git@github.com:acsl-tcu/acsl_package $ACSL_WORK_DIR/.install/main
  fi
  # update package_list
  cd $ACSL_WORK_DIR/.install/main
  git fetch
  package_list=($(git branch -a | grep remote | grep -v HEAD | grep -v main | sed -e "s|remotes/origin/||g"))
  cd $ACSL_WORK_DIR

  if [[ -n $(echo ${package_list[@]} | fmt -1 | grep -x $PACKAGE) ]]; then
    ## udev.rule
    remove_package_udev $PACKAGE
    ## systemd
    remove_package_systemd $PACKAGE

    if [[ -d $ACSL_WORK_DIR/.install/$PACKAGE ]]; then
      cd $ACSL_WORK_DIR/.install/$PACKAGE
      git pull
      cd $ACSL_WORK_DIR
    else
      git clone -b $PACKAGE --depth 1 git@github.com:acsl-tcu/acsl_package $ACSL_WORK_DIR/.install/$PACKAGE --recurse-submodules
    fi

    echo "Set udev rule"
    setup_udev $ACSL_WORK_DIR/.install/$PACKAGE/rules/${PACKAGE}.rules

    echo "Set ros launch"
    mkdir -p $ACSL_WORK_DIR/launcher
    cp -rp $ACSL_WORK_DIR/.install/$PACKAGE/launcher/* $ACSL_WORK_DIR/launcher/
    chmod -R a+x $ACSL_WORK_DIR/launcher

    if [[ -d $ACSL_WORK_DIR/.install/$PACKAGE/packages ]]; then
      echo "Install ROS package"
      mkdir -p $ACSL_WORK_DIR/packages
      cp -rp $ACSL_WORK_DIR/.install/$PACKAGE/packages/* $ACSL_WORK_DIR/packages/
    fi

    if [[ -f $ACSL_WORK_DIR/.install/$PACKAGE/dockerfiles/dockerfile.${PACKAGE} ]]; then
      echo "Build Docker image : dockerfile.${PACKAGE}"
      mkdir -p $ACSL_WORK_DIR/dockerfiles
      cp $ACSL_WORK_DIR/.install/$PACKAGE/dockerfiles/dockerfile.${PACKAGE} $ACSL_WORK_DIR/dockerfiles/
      dbuild image_${PROJECT}${x86} ${PACKAGE}${x86} ${PACKAGE}
    fi

    echo "set project_launch.sh"
    if ! grep -q "### $PACKAGE ###" $ACSL_WORK_DIR/project_launch.sh 2>/dev/null; then
      echo "### $PACKAGE ###" >>$ACSL_WORK_DIR/project_launch.sh
      echo "$ACSL_ROS2_DIR/commands/scripts/dup $@" >>$ACSL_WORK_DIR/project_launch.sh
      echo "### $PACKAGE END ###" >>$ACSL_WORK_DIR/project_launch.sh
    fi

    # setup の full パートにビルドコマンドを追記（プロジェクトイメージbuildの直後に挿入）
    if [[ -f $ACSL_WORK_DIR/setup ]] && ! grep -q "### $PACKAGE ###" $ACSL_WORK_DIR/setup; then
      sed -i "/dbuild.*image_/a\\
  ### ${PACKAGE} ###\\
  dbuild image_\${PROJECT}\${x86} ${PACKAGE}\${x86} ${PACKAGE}\\
  ### ${PACKAGE} END ###" $ACSL_WORK_DIR/setup
    fi

    gecho "Install complete: $PACKAGE"
  else
    recho "make package first as a branch on 'ros_package' repo"
  fi

  cd $SAVED_DIR
}

###################################################
function remove_package() {
  echo "Remove package"
  PACKAGE=$1
  ## udev.rule
  remove_package_udev $PACKAGE
  ## systemd
  remove_package_systemd $PACKAGE
  ## ros launch
  source $ACSL_ROS2_DIR/bashrc
  rm -fr $ACSL_WORK_DIR/launcher/launch_${PACKAGE}*
  ## ros package
  rm -fr $ACSL_WORK_DIR/.install/${PACKAGE}
  ## docker image
  drm all
  drmi $PACKAGE
}
# acsl switch_mode
# This script is used to switch modes in the ACSL environment.
# It handles various commands such as install, remove, update, freeze, clean, make_package, and more.
# [Usage]: acsl [command] [options]
# check_acsl and home functions are done in 99_main
function switch_mode() {
  source .acsl/bashrc
  case ${1} in
  "install")
    # acsl install package run_args
    # To install package
    if [ $# -ge 2 ]; then
      echo "install packages : ${@:2:($# - 1)}"
      install_package ${@:2:($# - 1)}
    else
      echo "Usage : acsl install package_name"
    fi
    ;;
  "remove")
    if [ $# -ge 2 ]; then
      echo "remove packages : ${@:2:($# - 1)}"
      remove_package ${@:2:($# - 1)}
    else
      echo "Usage : acsl remove package_name"
    fi
    ;;
  "update_tag_list")
    update_tag_list
    ;;
  "refresh_bashrc")
    echo "Regenerate .acsl/bashrc"
    rm -f $ACSL_ROS2_DIR/bashrc
    cp $ACSL_ROS2_DIR/bashrc.template $ACSL_ROS2_DIR/bashrc 2>/dev/null || touch $ACSL_ROS2_DIR/bashrc
    $ACSL_ROS2_DIR/commands/setup_bashrc $ACSL_WORK_DIR $PROJECT $ROS_DOMAIN_ID
    gecho "bashrc regenerated. Run: source .acsl/bashrc"
    ;;
  "clean")
    cd $ACSL_WORK_DIR
    echo "Delete ALL ACSL system"
    export PATH="$ORGPATH"
    echo "Deactivate udev"
    remove_udev
    echo "Unload systemd"
    remove_systemd
    echo "Delete project directory"
    cd $ACSL_WORK_DIR/..
    rm -fr $ACSL_WORK_DIR
    ;;
  "make_package")
    cd ~
    git clone --depth 1 git@github.com:acsl-tcu/acsl_package.git
    cd acsl_package
    git checkout -b $2
    git push -u origin $2
    ;;
  "setup_systemd")
    echo "setup systemd for autorun "
    gecho "After complete, reboot and check the ros node works"
    chmod -R a+x $ACSL_WORK_DIR/launcher
    if [[ -f project_launch.sh ]]; then
      chmod a+x $ACSL_WORK_DIR/project_launch.sh
      $ACSL_ROS2_DIR/commands/setup_systemd $ACSL_WORK_DIR/project_launch.sh
    fi
    ;;
  "remove_systemd")
    remove_systemd
    ;;
  "setup_udev")
    setup_udev
    ;;
  "remove_udev")
    remove_udev
    ;;
  "man")
    man $2
    ;;
  esac
}
###################################################
# Main part
# [flow]
# /check_acsl
# |-N> change_dir_for_init
#   |> check_empty
#      |-Y> initialize_project
#      |-N> $# == 1 -> enter the project
#            |-N>exit
# |-Y> home
#      |> switch_mode
###################################################
if [[ "${1-}" = "--version" || "${1-}" = "-v" ]]; then
  print_acsl_version
  exit 0
fi

if check_acsl; then
  switch_mode $@
else
  change_dir_for_init $1
  if check_empty; then
    initialize_project ${@:2:($# - 1)}
  elif [ $# -eq 1 ]; then
    cd ~/$1/.acsl
    commands/scripts/set_bashrc "export DISPLAY" $DISPLAY # remote desktop用
    cd ~/$1
    bash --rcfile .acsl/bashrc
  else
    man init
    exit 1
  fi
fi
